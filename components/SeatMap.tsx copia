'use client';

export default function SeatMap({ seats, selected, onToggle }: any) {
  function toggle(id: string, status: string) {
    if (status !== 'available') return;
    onToggle((prev: string[]) =>
      prev.includes(id) ? prev.filter((x) => x !== id) : [...prev, id]
    );
  }

  function getSeatFill(seat: any, isSelected: boolean) {
    if (seat.status === 'sold') return '#d9534f';
    if (seat.status === 'locked') return '#f0ad4e';
    if (isSelected) return '#0275d8';
    return '#5cb85c';
  }

  function getPlateaRowConfig(rowNumber: number) {
    if (rowNumber >= 1 && rowNumber <= 6) {
      return { groups: [16] };
    }

    if (rowNumber === 7 || rowNumber === 8) {
      return { groups: [9, 7] };
    }

    if (rowNumber === 9 || rowNumber === 10) {
      return { groups: [9, 9] };
    }

    if (rowNumber >= 11 && rowNumber <= 14) {
      return { groups: [10, 10] };
    }

    return null;
  }

  function getPlateaSeatPosition(rowLabel: string, seatNumber: number) {
    const rowNumber = Number(rowLabel);
    const rowConfig = getPlateaRowConfig(rowNumber);

    if (!rowConfig) return null;

    const centerX = 600;
    const startY = 170;
    const rowGap = 52;
    const seatGap = 36;
    const aisleGap = 78;
    const radius = 14;

    const groupPositions: number[] = [];
    let cursor = 0;

    rowConfig.groups.forEach((count, groupIndex) => {
      for (let i = 0; i < count; i++) {
        groupPositions.push(cursor + i * seatGap);
      }
      cursor += count * seatGap;
      if (groupIndex < rowConfig.groups.length - 1) {
        cursor += aisleGap;
      }
    });

    let seatIndex = -1;

    if (rowConfig.groups.length === 1) {
      if (seatNumber >= 1 && seatNumber <= 16) {
        seatIndex = seatNumber - 1;
      }
    }

    if (rowConfig.groups.length === 2) {
      const leftCount = rowConfig.groups[0];
      const rightCount = rowConfig.groups[1];

      if (rowNumber === 7 || rowNumber === 8) {
        if (seatNumber >= 1 && seatNumber <= 9) {
          seatIndex = seatNumber - 1;
        } else if (seatNumber >= 10 && seatNumber <= 16) {
          seatIndex = leftCount + (seatNumber - 10);
        }
      }

      if (rowNumber === 9 || rowNumber === 10) {
        if (seatNumber >= 1 && seatNumber <= 9) {
          seatIndex = seatNumber - 1;
        } else if (seatNumber >= 10 && seatNumber <= 18) {
          seatIndex = leftCount + (seatNumber - 10);
        }
      }

      if (rowNumber >= 11 && rowNumber <= 14) {
        if (seatNumber >= 1 && seatNumber <= 10) {
          seatIndex = seatNumber - 1;
        } else if (seatNumber >= 11 && seatNumber <= 20) {
          seatIndex = leftCount + (seatNumber - 11);
        }
      }

      // Evita warning TS per rightCount non usato
      void rightCount;
    }

    if (seatIndex < 0 || seatIndex >= groupPositions.length) {
      return null;
    }

    const rowWidth = groupPositions[groupPositions.length - 1];
    const startX = centerX - rowWidth / 2;
    const x = startX + groupPositions[seatIndex];
    const y = startY + (rowNumber - 1) * rowGap;

    return { x, y, r: radius };
  }

  function getGalleriaSeatPosition(meta: any) {
    const x = Number(meta.x_coord || 0);
    const y = Number(meta.y_coord || 0);

    return {
      x: x * 1.05 + 40,
      y: y * 0.95 + 260,
      r: 13,
    };
  }

  function getVisualSeat(seat: any) {
    const meta = seat.venue_seats;
    const section = String(meta.section_code || '');
    const rowLabel = String(meta.row_label || '');
    const seatNumber = Number(meta.seat_number || 0);

    if (section === 'PLATEA') {
      return getPlateaSeatPosition(rowLabel, seatNumber);
    }

    if (section === 'GALLERIA') {
      return getGalleriaSeatPosition(meta);
    }

    return {
      x: Number(meta.x_coord || 0),
      y: Number(meta.y_coord || 0),
      r: Number(meta.seat_radius || 12),
    };
  }

  return (
    <div
      style={{
        border: '1px solid #ddd',
        borderRadius: 12,
        padding: 16,
        overflow: 'auto',
      }}
    >
      <svg width="1200" height="980" viewBox="0 0 1200 980">
        <text x="560" y="40" fontSize="26" fontWeight="700">
          PALCO
        </text>

        <text x="540" y="95" fontSize="20" fontWeight="700">
          PLATEA
        </text>

        <text x="520" y="805" fontSize="20" fontWeight="700">
          GALLERIA
        </text>

        {seats.map((seat: any) => {
          const meta = seat.venue_seats;
          const visual = getVisualSeat(seat);

          if (!visual) return null;

          const isSelected = selected.includes(seat.id);
          const fill = getSeatFill(seat, isSelected);

          return (
            <g
              key={seat.id}
              onClick={() => toggle(seat.id, seat.status)}
              style={{
                cursor: seat.status === 'available' ? 'pointer' : 'not-allowed',
              }}
            >
              <circle
                cx={visual.x}
                cy={visual.y}
                r={visual.r}
                fill={fill}
              />
              <title>
                {meta.seat_label} - € {(seat.price_cents / 100).toFixed(2)} - {seat.status}
              </title>
            </g>
          );
        })}
      </svg>
    </div>
  );
}